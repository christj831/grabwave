SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Web UI: optional — sign in at /auth/spotify stores token in session; no .env needed.
# CLI only: optional paste after one-time OAuth if you do not use the web login
# SPOTIFY_REFRESH_TOKEN=

# Must match Redirect URI in Spotify Developer Dashboard (default if unset)
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/spotify/callback

# Catalog region. Use empty to omit market: SPOTIFY_MARKET=
# SPOTIFY_MARKET=US

# Random string for session cookies (set in production)
# SESSION_SECRET=
